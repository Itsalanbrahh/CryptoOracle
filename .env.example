# ── Core AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
NEWSAPI_KEY=                        # optional — RSS fallback used if blank

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Get keys at https://app.alpaca.markets → Paper Account → API Keys
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_PAPER=true                   # set false to use live account (be careful)
ALPACA_MAX_ORDER_USD=20000          # hard cap per order

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram, then /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=          # optional comma-separated whitelist

# ── Scheduler ─────────────────────────────────────────────────────────────────
ORACLE_INTERVAL_MINUTES=240         # how often to run the full oracle (default 4h)
HEARTBEAT_INTERVAL_MINUTES=360      # how often to send a status heartbeat (default 6h)
ALERT_THRESHOLD=0.70                # min confidence to trigger proactive alert
WATCHLIST=BTC,ETH                   # comma-separated symbols to track

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=*                   # CORS — restrict in production

# ── Kronos (shiyu-coder/Kronos financial OHLCV foundation model) ─────────────
# Run 'make kronos-setup' first to clone the model repo into vendor/kronos
KRONOS_REPO_PATH=vendor/kronos

# Model options (all from HuggingFace NeoQuasar org):
#   NeoQuasar/Kronos-mini   —  4.1M params, 2048 ctx  (fastest, ~20MB)
#   NeoQuasar/Kronos-small  — 24.7M params,  512 ctx  (default, ~100MB)
#   NeoQuasar/Kronos-base   — 102.3M params, 512 ctx  (most accurate, ~400MB)
KRONOS_MODEL=NeoQuasar/Kronos-small
# KRONOS_TOKENIZER is auto-set based on model; override only if needed
# KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base

# ── Feature Flags ─────────────────────────────────────────────────────────────
SKIP_KRONOS=false                   # set true to skip Kronos entirely (uses GBM fallback)
SKIP_ALPACA=false                   # set true to disable all Alpaca integration
