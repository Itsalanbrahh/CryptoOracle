# ── Core AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
NEWSAPI_KEY=                        # optional — RSS fallback used if blank

# ── Alpaca Paper Trading ──────────────────────────────────────────────────────
# Get keys at https://app.alpaca.markets → Paper Account → API Keys
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_PAPER=true                   # set false to use live account (be careful)
ALPACA_MAX_ORDER_USD=500            # hard cap per order

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram, then /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=          # optional comma-separated whitelist

# ── Scheduler ─────────────────────────────────────────────────────────────────
ORACLE_INTERVAL_MINUTES=240         # how often to run the full oracle (default 4h)
HEARTBEAT_INTERVAL_MINUTES=360      # how often to send a status heartbeat (default 6h)
ALERT_THRESHOLD=0.70                # min confidence to trigger proactive alert
WATCHLIST=BTC,ETH                   # comma-separated symbols to track

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=*                   # CORS — restrict in production

# ── Feature Flags ─────────────────────────────────────────────────────────────
SKIP_KRONOS=false                   # set true to skip Monte Carlo agent (saves time)
SKIP_ALPACA=false                   # set true to disable all Alpaca integration
